# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
# Public keys (safe to expose to the browser). Found in:
#   Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only key. NEVER expose this to the browser or commit it.
# Used by server actions / API routes to write leads and scan data.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---------------------------------------------------------------------------
# Future integrations (not required for the MVP foundation)
